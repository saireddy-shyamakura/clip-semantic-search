# Momento Configuration
# Copy this file to .env and adjust values as needed.
# Environment variables take precedence over config file and defaults.

# ── Embedding Model ──────────────────────────────────────────────────
# Supported: ViT-B/32, ViT-B/16 (default), ViT-L/14, ViT-L/14@336px, ConvNeXt-B
# MOMENTO_MODEL_NAME=ViT-B/16

# ── Device ───────────────────────────────────────────────────────────
# Auto-detected: cuda, mps, cpu
# Override with: MOMENTO_DEVICE=cpu

# ── Feature Toggles ─────────────────────────────────────────────────
# Set to "false" to disable features (all enabled by default)
# MOMENTO_ENABLE_MULTI_EMBED=true
# MOMENTO_ENABLE_VIDEO_INDEXING=true
# MOMENTO_ENABLE_YOLO=true
# MOMENTO_ENABLE_OCR=true

# ── Similarity ──────────────────────────────────────────────────────
# MOMENTO_SIMILARITY_THRESHOLD=0.20
# MOMENTO_MAX_SEARCH_RESULTS=50

# ── Indexing ─────────────────────────────────────────────────────────
# MOMENTO_AUGMENTATION_COUNT=5
# MOMENTO_INDEXING_BATCH_SIZE=32
# MOMENTO_VIDEO_FRAME_INTERVAL=2.0

# ── YOLO ─────────────────────────────────────────────────────────────
# MOMENTO_YOLO_MODEL=yolov8n.pt

# ── Cache ────────────────────────────────────────────────────────────
# MOMENTO_CACHE_MAX_SIZE_GB=5

# ── Logging ──────────────────────────────────────────────────────────
# Format: "text" or "json"
# Level: "DEBUG", "INFO", "WARNING", "ERROR"
# MOMENTO_LOG_FORMAT=text
# MOMENTO_LOG_LEVEL=INFO